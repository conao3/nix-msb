{
  lib,
  dockerTools,
  runCommand,
  writeShellApplication,
  microsandbox,
  jq,
}:

{
  name,
  contents ? [ ],
  config ? { },
}:

let
  cmd = config.cmd or [ "/bin/sh" ];

  imageConfig = {
    Cmd = cmd;
  }
  // lib.optionalAttrs (config ? env) {
    Env = lib.mapAttrsToList (k: v: "${k}=${v}") config.env;
  }
  // lib.optionalAttrs (config ? user) { User = config.user; }
  // lib.optionalAttrs (config ? workdir) { WorkingDir = config.workdir; };

  image = dockerTools.buildLayeredImage {
    inherit name contents;
    tag = "latest";
    config = imageConfig;
  };

  rootfs =
    runCommand "${name}-rootfs"
      {
        nativeBuildInputs = [ jq ];
      }
      ''
        mkdir -p $out
        work=$(mktemp -d)
        tar -xzf ${image} -C "$work"
        for layer in $(jq -r '.[0].Layers[]' "$work/manifest.json"); do
          tar -xf "$work/$layer" -C $out
        done

        mkdir -p $out/etc
        [ -f $out/etc/passwd ] || echo 'root:x:0:0:root:/root:/bin/sh' > $out/etc/passwd
        [ -f $out/etc/group ]  || echo 'root:x:0:' > $out/etc/group
        [ -f $out/etc/os-release ] || cat > $out/etc/os-release <<EOF
        NAME="${name}"
        ID=nix-msb
        EOF
      '';

  netFlags =
    let
      net = config.net or null;
    in
    if net == "none" then
      [ "--no-net" ]
    else if net == null || net == "public" || net == "any" then
      [ ]
    else
      throw "nix-msb: unsupported config.net value: ${toString net} (use \"none\" | \"public\" | \"any\")";

  resourceFlags =
    lib.optionals (config ? cpus) [
      "--cpus"
      (toString config.cpus)
    ]
    ++ lib.optionals (config ? memory) [
      "--memory"
      config.memory
    ]
    ++ lib.optionals (config ? user) [
      "--user"
      config.user
    ]
    ++ lib.optionals (config ? workdir) [
      "--workdir"
      config.workdir
    ];

  envFlags = lib.concatMap (kv: [
    "--env"
    "${kv.name}=${kv.value}"
  ]) (lib.mapAttrsToList lib.nameValuePair (config.env or { }));

  portFlags = lib.concatMap (p: [
    "--port"
    p
  ]) (config.ports or [ ]);

  msbArgs = lib.concatStringsSep " " (
    map lib.escapeShellArg (netFlags ++ resourceFlags ++ envFlags ++ portFlags)
  );

  cmdArgs = lib.concatStringsSep " " (map lib.escapeShellArg cmd);

  launch = writeShellApplication {
    name = "${name}-launch";
    runtimeInputs = [ microsandbox ];
    text = ''
      tmpdir=$(mktemp -d -t msb-${name}-XXXXXX)
      trap 'rm -rf "$tmpdir"' EXIT
      cp -a ${rootfs}/. "$tmpdir"/
      chmod -R u+w "$tmpdir"
      if [ "$#" -gt 0 ]; then
        exec msb run ${msbArgs} "$tmpdir" -- "$@"
      else
        exec msb run ${msbArgs} "$tmpdir" -- ${cmdArgs}
      fi
    '';
  };

  sandboxfile = runCommand "${name}-sandboxfile" { } ''
    cat > $out <<EOF
    # Sandboxfile for ${name}
    # Generated by nix-msb. Schema rendering is not yet implemented.
    # Use ${name}-launch instead for now.
    EOF
  '';
in
{
  inherit
    rootfs
    image
    launch
    sandboxfile
    ;
}
